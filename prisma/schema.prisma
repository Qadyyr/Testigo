// Testigo ‚Äî Prisma schema
// DB: PostgreSQL (Neon). All "enum-ish" fields are String with documented
// allowed values, enforced via Zod in the API layer. Json fields are native
// Postgres JSON. Designed for serverless (Vercel) + Neon serverless Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Admin ‚Äî the only authenticated user type. Participants never have accounts.
// `role` ‚àà { "ADMIN", "SUPER_ADMIN" }
// ---------------------------------------------------------------------------
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("ADMIN") // ADMIN | SUPER_ADMIN
  status       String   @default("APPROVED") // PENDING | APPROVED | REJECTED | SUSPENDED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tests Test[]
}

// ---------------------------------------------------------------------------
// Test ‚Äî a single exam/survey.
//
// ACCESS MODEL (Option B ‚Äî primary gate + optional code overlay):
//   `accessMode` ‚àà { "PUBLIC", "WHITELIST", "INVITE" }   (primary gate)
//   `requireCode` Boolean + `accessCode` String?           (optional overlay)
//
//   - PUBLIC    + requireCode=false ‚Üí anyone with the link
//   - PUBLIC    + requireCode=true  ‚Üí link + code (the old "CODE" mode)
//   - WHITELIST + (requireCode any) ‚Üí only registered identifiers (+ optional code)
//   - INVITE    + (requireCode any) ‚Üí single-use invite links (+ optional code)
//
// `resultReleaseMode` ‚àà { "IMMEDIATE", "MANUAL", "NEVER" }
//   - IMMEDIATE ‚Üí student sees score + answers right after submit
//   - MANUAL    ‚Üí "results pending" until admin releases (Phase 5)
//   - NEVER     ‚Üí score never shown to students (admin-only)
//
// `shareableLink` ‚Äî unguessable nanoid token used in `/?t=<token>`.
// ---------------------------------------------------------------------------
model Test {
  id                String   @id @default(cuid())
  title             String
  description       String?
  startTime         DateTime? // scheduled open (nullable = open immediately)
  endTime           DateTime? // scheduled close (nullable = no close)
  timezone          String? // IANA tz, e.g. "Asia/Karachi"
  timeLimitMinutes  Int? // null = no time limit
  accessMode        String   @default("PUBLIC") // PUBLIC | WHITELIST | INVITE
  requireCode       Boolean  @default(false) // optional code overlay
  accessCode        String? // set when requireCode = true
  maxAttempts       Int      @default(1)
  resultReleaseMode String   @default("IMMEDIATE") // IMMEDIATE | MANUAL | NEVER
  positiveMarks     Float    @default(1)
  negativeMarks     Float    @default(0)
  partialMarks      Boolean  @default(false) // partial credit on multi-correct MCQ
  isPublished       Boolean  @default(false)
  shareableLink     String   @unique
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  admin        Admin        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  questions    Question[]
  whitelists   Whitelist[]
  invitations  Invitation[]
  participants Participant[]
  attempts     Attempt[]

  @@index([createdBy])
  @@index([isPublished])
}

// ---------------------------------------------------------------------------
// Question
// `type` ‚àà { "MCQ", "TRUE_FALSE", "SHORT" }
//   - MCQ        ‚Üí multiple choice (single or multi-correct)
//   - TRUE_FALSE ‚Üí binary (auto-generates ["True","False"] options if empty)
//   - SHORT      ‚Üí short text answer (auto-graded against acceptable answers)
// `options`        ‚Äî JSON: string[] (MCQ / TRUE_FALSE). [] for SHORT.
// `correctAnswers` ‚Äî JSON:
//   - MCQ / TRUE_FALSE ‚Üí number[] (indices into options)
//   - SHORT           ‚Üí string[] (acceptable answers; case-insensitive match)
// `explanation`    ‚Äî optional, shown in the result review to explain why the
//   answer is correct. Set by admin in the import, never by the participant.
// `positiveMarks` / `negativeMarks` ‚Äî default to the test-level values; can be
//   overridden per-question for advanced use (not exposed in the simple import).
// ---------------------------------------------------------------------------
model Question {
  id             String   @id @default(cuid())
  testId         String
  questionText   String
  type           String   @default("MCQ") // MCQ | TRUE_FALSE | SHORT
  options        Json // string[]
  correctAnswers Json // number[] | string[]
  explanation    String?
  positiveMarks  Float    @default(1)
  negativeMarks  Float    @default(0)
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  test      Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  responses Response[]

  @@index([testId])
}

// ---------------------------------------------------------------------------
// Whitelist ‚Äî identifiers allowed to take a WHITELIST test.
// `identifier`     ‚Äî the value (currently a phone number; later email/student-ID).
// `identifierType` ‚àà { "PHONE" } for now; additive later (EMAIL, STUDENT_ID).
// Generic column name means adding new identifier types is a backfill, not a rename.
// ---------------------------------------------------------------------------
model Whitelist {
  id             String   @id @default(cuid())
  testId         String
  identifier     String
  identifierType String   @default("PHONE") // PHONE | (EMAIL | STUDENT_ID future)
  createdAt      DateTime @default(now())

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, identifier])
  @@index([testId])
}

// ---------------------------------------------------------------------------
// Invitation ‚Äî single-use, unguessable links for INVITE-access tests.
// Each student gets a unique token (/?invite=<token>); `usedAt` is set when
// consumed, so a link works exactly once. Possession of the link IS the proof
// of invitation (no OTP needed) ‚Äî the free secure identity model.
// ---------------------------------------------------------------------------
model Invitation {
  id        String    @id @default(cuid())
  testId    String
  token     String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
}

// ---------------------------------------------------------------------------
// Participant ‚Äî a verified test-taker for a specific test (no global account).
// `identifier` / `identifierType` mirror the Whitelist columns.
// For PUBLIC tests, a participant row is created on start with the (optional)
// identifier they provided; for INVITE tests, the identifier is the invite token.
// ---------------------------------------------------------------------------
model Participant {
  id             String    @id @default(cuid())
  testId         String
  name           String?
  identifier     String?
  identifierType String    @default("PHONE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  test     Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@unique([testId, identifier])
  @@index([testId])
}

// ---------------------------------------------------------------------------
// Attempt ‚Äî one taking of a test by a participant.
// `status` ‚àà { "IN_PROGRESS", "SUBMITTED", "AUTO_SUBMITTED" }
// `startTime` ‚Äî backend-written the moment verification passes; the source of
//   truth for the timer (never trust client clocks).
// `tabSwitches` ‚Äî anti-cheat counter (visibilitychange events).
// `totalScore` ‚Äî computed on the backend at submission (0-100 percentage).
// ---------------------------------------------------------------------------
model Attempt {
  id            String    @id @default(cuid())
  testId        String
  participantId String
  startTime     DateTime
  endTime       DateTime?
  status        String    @default("IN_PROGRESS") // IN_PROGRESS | SUBMITTED | AUTO_SUBMITTED
  totalScore    Float?
  tabSwitches   Int       @default(0)
  createdAt     DateTime  @default(now())

  test        Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  responses   Response[]

  @@index([testId])
  @@index([participantId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Response ‚Äî one answer to one question within one attempt.
// `userAnswer` ‚Äî JSON:
//   - MCQ  ‚Üí number[] (selected indices)
//   - TEXT ‚Üí string
// `isCorrect` / `marksAwarded` ‚Äî null until graded.
//   MCQ is auto-graded on submit; TEXT stays null (pending manual review).
// ---------------------------------------------------------------------------
model Response {
  id           String   @id @default(cuid())
  attemptId    String
  questionId   String
  userAnswer   Json?
  isCorrect    Boolean?
  marksAwarded Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}
