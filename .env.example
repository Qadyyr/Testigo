# Copy to .env and fill in your values.

# Neon Postgres connection string.
# Get this from your Neon dashboard → Connection Details → "Pooled connection".
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth secret — generate with: openssl rand -base64 32
# (or any random 32+ char string)
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# The canonical URL of your deployed app (used by NextAuth for callbacks).
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
